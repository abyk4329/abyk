# Environment example for Awakening by Ksenia
# Copy to .env.local and adjust secrets

# App base URLs
BASE_URL=https://abyk.online
NEXT_PUBLIC_BASE_URL=https://abyk.online

# Payments
# If left empty, the app will fallback to the Grow checkout URL below.
# Recommended: set your own per-environment value in Vercel.
NEXT_PUBLIC_PAYMENT_URL=

# Email (Gmail SMTP - use App Password)
EMAIL_USER=
EMAIL_PASSWORD=

# Webhook security
WEBHOOK_SECRET=
