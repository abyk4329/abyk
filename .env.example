# Copy to .env.local and fill in values for local runs
# Vercel: set these in Project Settings → Environment Variables

# Optional shared secret for Grow webhook validation
# If set, incoming requests must send the same value in `x-grow-signature`
GROW_WEBHOOK_SECRET=

# Server email (Resend)
RESEND_API_KEY=
EMAIL_FROM="AWAKENING <noreply@abyk.online>"

# Client fallback (EmailJS) — optional and not recommended for prod
NEXT_PUBLIC_EMAILJS_SERVICE_ID=
NEXT_PUBLIC_EMAILJS_TEMPLATE_ID=
NEXT_PUBLIC_EMAILJS_PUBLIC_KEY=
